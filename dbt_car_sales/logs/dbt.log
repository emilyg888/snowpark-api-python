join SNOWPARK_SAMPLE_DATA.STAGING.stg_car_sales_extras extra
  on vehicle.source_sale_key = extra.source_sale_key
 and vehicle.vehicle_index = extra.vehicle_index
where extra.extra_key is not null
    )

